root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,yml,yaml,json,js,ts,vue,html,css,scss}]
indent_size = 2

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.csv]
indent_size = 2

[Makefile]
indent_style = tab

